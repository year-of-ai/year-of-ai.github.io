# =============================================================================
# {{REPO}} — GitHub Pages configuration (zer0-mistakes org hub scaffold)
# =============================================================================
# Generated by zer0-mistakes/scripts/provision-org-sites.rb from
# templates/org-site/_config.yml.template — re-run the provisioner to update.
#
# Publishing: GitHub Pages, "deploy from branch" ({{BRANCH}}, path /).
# Site URL:   https://{{ORG}}.github.io/{{REPO}}/
# Theme:      remote_theme {{THEME_REPO}} (no theme files vendored here).
#
# Content stays plain markdown in this repo. The GitHub Pages default plugins
# (optional-front-matter, readme-index, default-layout, titles-from-headings,
# relative-links) turn it into pages without any front-matter requirements.
# =============================================================================

site_configured: true

title: "{{REPO_TITLE}}"
description: "{{REPO_DESCRIPTION}}"

github_user: "{{ORG}}"
repository_name: "{{REPO}}"
repository: "{{ORG}}/{{REPO}}"

url: "https://{{ORG}}.github.io"
baseurl: "/{{REPO}}"
remote_theme: "{{THEME_REPO}}"

markdown: kramdown
kramdown:
  input: GFM
permalink: pretty

# GitHub Pages enables all of these by default; listing them keeps local
# builds (github-pages gem) identical to production.
#
# jekyll-include-cache is REQUIRED: the remote theme's layouts use the
# {% include_cached %} tag (e.g. _includes/components/setup-banner.html), and
# the consuming site must load the plugin that provides it or the build fails
# with "Unknown tag 'include_cached'". It is on the GitHub Pages whitelist.
plugins:
  - jekyll-remote-theme
  - jekyll-include-cache
  - jekyll-seo-tag
  - jekyll-sitemap
  - jekyll-feed
  - jekyll-relative-links
  - jekyll-optional-front-matter
  - jekyll-readme-index
  - jekyll-default-layout
  - jekyll-titles-from-headings

# Markdown files without front matter become pages (don't also copy the raw
# .md into the output).
optional_front_matter:
  remove_originals: true

# Relative .md links between files rewrite to the rendered page URLs.
relative_links:
  enabled: true

# Pages without an explicit title take it from their first heading. The body
# H1 stays in place (see hide_intro below), so don't strip it.
titles_from_headings:
  enabled: true
  strip_title: false

defaults:
  - scope:
      path: ""
    values:
      layout: default
      # Content files carry their own H1; skip the theme's intro header so
      # the heading doesn't render twice.
      hide_intro: true
      author_profile: false
      read_time: true
      share: true
      sidebar:
        nav: main

# Repo/agent plumbing that must not publish as site pages.
#
# NOTE: seed.md and ROADMAP.md are intentionally NOT excluded — the repo README
# (the site homepage via jekyll-readme-index) links to seed.md, and seed.md
# links to ROADMAP.md. Excluding them leaves those relative links un-rewritten
# by jekyll-relative-links, producing 404s on every homepage. Publishing them
# (at /seed/ and /roadmap/) lets the links resolve. They are still kept out of
# the navbar via _data/hub.yml `defaults.exclude` in the theme repo.
exclude:
  - CLAUDE.md
  - AGENTS.md
  - LIFECYCLE.md
  - lifecycle.yml
  - seed-package/
  - telemetry/
  - .claude/
  - Gemfile
  - Gemfile.lock
  - vendor/
  - node_modules/
