{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "genome.yml — org-model concept manifest",
  "description": "The minimal concept-delta that, with the genome's transplant tiers, stands up the whole self-growing org model for a new concept.",
  "type": "object",
  "required": ["genome_version", "identity", "branding", "lexicon", "taxonomy", "lifecycle"],
  "additionalProperties": true,
  "properties": {
    "genome_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$", "description": "must equal genome/CHANGELOG.md head" },
    "identity": {
      "type": "object",
      "required": ["org", "hub_repo", "hub_domain", "theme_repo"],
      "properties": {
        "org": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "hub_repo": { "type": "string" },
        "hub_domain": { "type": "string" },
        "git_author_email": { "type": "string", "format": "email" },
        "theme_repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" }
      }
    },
    "branding": {
      "type": "object",
      "required": ["site_title", "site_tagline"],
      "properties": {
        "site_title": { "type": "string", "minLength": 1 },
        "site_tagline": { "type": "string", "minLength": 1 },
        "founder_name": { "type": "string" },
        "founder_email": { "type": "string" },
        "copyright_year": { "type": "integer" }
      }
    },
    "lexicon": {
      "type": "object",
      "required": ["unit_noun", "member_subject_template"],
      "properties": {
        "unit_noun": { "type": "string", "minLength": 1 },
        "unit_noun_plural": { "type": "string" },
        "unit_icon": { "type": "string" },
        "member_subject_template": { "type": "string", "pattern": "\\{member\\}", "description": "must contain the {member} placeholder" }
      }
    },
    "taxonomy": {
      "type": "object",
      "required": ["taxonomy_strategy", "default_taxonomy"],
      "properties": {
        "taxonomy_strategy": { "enum": ["temporal", "enumerable", "hierarchical"] },
        "default_taxonomy": {
          "type": "array", "minItems": 4, "maxItems": 8,
          "items": {
            "type": "object", "required": ["name", "slug"],
            "properties": { "name": { "type": "string" }, "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } }
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["first_member", "succession_rule"],
      "properties": {
        "first_member": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "succession_rule": { "type": "string", "minLength": 1 }
      }
    },
    "cadence": {
      "type": "object",
      "properties": {
        "cron": { "type": "string" },
        "replant_after_ticks": { "type": "integer" },
        "consolidate_at_members": { "type": "integer" }
      }
    },
    "growth": {
      "type": "object",
      "properties": {
        "web_sources": { "type": "boolean", "description": "false = generate from the model's own knowledge, no WebFetch/WebSearch (plant.rb strips them)" }
      }
    }
  }
}
